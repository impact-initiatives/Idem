linters: linters_with_defaults(
    object_usage_linter = NULL
  )
exclusions: list(
    "R/read_xlsform.R" = list(
      line_length_linter = 50L
    ),
    "R/validate_xlsform.R" = list(
      line_length_linter = c(17L, 18L, 19L)
    ),
    "R/xlsform_choices_list_names.R" = list(
      line_length_linter = 16L
    ),
    "README.Rmd" = list(
      line_length_linter = Inf,
      indentation_linter = Inf
    )
  )
